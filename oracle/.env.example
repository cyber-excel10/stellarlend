# =============================================================================
# StellarLend Oracle Service — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values before starting the oracle.
#   cp .env.example .env
#
# The oracle fetches off-chain asset prices from CoinGecko, CoinMarketCap, and
# Binance, then pushes them to the StellarLend on-chain price feed contract.
#
# Legend:
#   [REQUIRED] — the service will fail to start if this is missing or invalid
#   [OPTIONAL] — a safe default is used when not set
#   [SECRET]   — never commit the real value; use a secrets manager in production
# =============================================================================

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------

# Runtime environment. Affects default overrides for update interval and dry-run.
# Accepted values: development | production
# [OPTIONAL] Default: development
NODE_ENV=development

# -----------------------------------------------------------------------------
# Stellar / Soroban Network
# -----------------------------------------------------------------------------

# Network the oracle writes price data to.
# Accepted values: testnet | mainnet
# [OPTIONAL] Default: testnet
STELLAR_NETWORK=testnet

# Soroban RPC endpoint. Falls back to the network default when not set.
# Testnet default: https://soroban-testnet.stellar.org
# Mainnet default: https://soroban.stellar.org
# [OPTIONAL]
# STELLAR_RPC_URL=

# Base transaction fee in stroops (1 XLM = 10,000,000 stroops).
# Must be <= STELLAR_MAX_FEE. Falls back to the network default when not set.
# Testnet default: 100000  Mainnet default: 200000
# [OPTIONAL]
# STELLAR_BASE_FEE=

# Maximum fee the oracle will pay per transaction (stroops).
# Transactions are dropped when the network fee exceeds this value.
# [OPTIONAL] Default: 1000000
STELLAR_MAX_FEE=1000000

# Deployed StellarLend price-feed contract address.
# [REQUIRED]
CONTRACT_ID=

# Stellar secret key (S...) of the admin account used to sign price-update txns.
# Testnet keys: https://laboratory.stellar.org/#account-creator?network=testnet
# [REQUIRED] [SECRET]
ADMIN_SECRET_KEY=

# -----------------------------------------------------------------------------
# Price Data Providers
# -----------------------------------------------------------------------------

# CoinGecko API key.
# Without a key the free public API is used (rate-limited to ~10 req/min).
# With a Pro key the limit rises to 500 req/min and the Pro base URL is used.
# [OPTIONAL] [SECRET]
COINGECKO_API_KEY=

# CoinMarketCap API key.
# When not set the CoinMarketCap provider is disabled entirely.
# Obtain from: https://pro.coinmarketcap.com/
# [OPTIONAL] [SECRET]
COINMARKETCAP_API_KEY=

# -----------------------------------------------------------------------------
# Redis Cache
# -----------------------------------------------------------------------------

# Redis connection URL used to cache fetched prices between update cycles.
# When not set an in-memory cache is used (prices are lost on restart).
# [OPTIONAL]
REDIS_URL=

# How long a cached price entry is considered fresh (seconds).
# [OPTIONAL] Default: 30
CACHE_TTL_SECONDS=30

# -----------------------------------------------------------------------------
# Price Update Cycle
# -----------------------------------------------------------------------------

# How often the oracle fetches prices and pushes an on-chain update (ms).
# [OPTIONAL] Default: 60000 (1 min)
UPDATE_INTERVAL_MS=60000

# Dry-run mode: fetch and validate prices but do NOT submit on-chain transactions.
# Useful for testing without spending XLM.
# Accepted values: true | false
# [OPTIONAL] Default: false (overridden to true in development config)
DRY_RUN=false

# -----------------------------------------------------------------------------
# Price Validation
# -----------------------------------------------------------------------------

# Maximum allowed percentage deviation between the new price and the last
# accepted price before the update is rejected as anomalous.
# [OPTIONAL] Default: 10
MAX_PRICE_DEVIATION_PERCENT=10

# Maximum age (seconds) of a cached price before it is flagged as stale.
# Stale prices trigger a warning and are excluded from aggregation.
# [OPTIONAL] Default: 300 (5 min)
PRICE_STALENESS_THRESHOLD_SECONDS=300

# -----------------------------------------------------------------------------
# Circuit Breaker
# -----------------------------------------------------------------------------

# Number of consecutive provider failures before the circuit trips open and
# the oracle pauses updates to that provider.
# [OPTIONAL] Default: 3
CIRCUIT_BREAKER_FAILURE_THRESHOLD=3

# Time (ms) the circuit stays open before attempting recovery.
# [OPTIONAL] Default: 30000 (30 s)
CIRCUIT_BREAKER_BACKOFF_MS=30000

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# Minimum log level emitted.
# Accepted values: debug | info | warn | error
# [OPTIONAL] Default: info
LOG_LEVEL=info
