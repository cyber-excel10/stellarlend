{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "resolveJsonModule": true,
    "declarationMap": true,
    "baseUrl": "./src",
    "paths": {
      "@/claims/*": ["claims/*"],
      "@/config/*": ["config/*"],
      "@/devtools/*": ["devtools/*"],
      "@/providers/*": ["providers/*"],
      "@/security/*": ["security/*"],
      "@/services/*": ["services/*"],
      "@/types/*": ["types/*"],
      "@/utils/*": ["utils/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "tests"]
}
