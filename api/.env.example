# =============================================================================
# StellarLend API — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values before starting the server.
#   cp .env.example .env
#
# Legend:
#   [REQUIRED] — the server will refuse to start if this is missing or invalid
#   [OPTIONAL] — a safe default is used when not set
#   [SECRET]   — never commit the real value; use a secrets manager in production
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------

# Port the HTTP server listens on.
# [OPTIONAL] Default: 3000
PORT=3000

# Runtime environment. Affects CORS policy, HTTPS enforcement, and log format.
# Accepted values: development | staging | production
# [OPTIONAL] Default: development
NODE_ENV=development

# -----------------------------------------------------------------------------
# Stellar / Soroban Network
# -----------------------------------------------------------------------------

# Network to connect to.
# Accepted values: testnet | mainnet
# [OPTIONAL] Default: testnet
STELLAR_NETWORK=testnet

# Horizon REST API base URL.
# [OPTIONAL] Default: https://horizon-testnet.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org

# Soroban RPC endpoint for smart-contract interactions.
# [OPTIONAL] Default: https://soroban-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Stellar network passphrase — used to sign transactions.
# Testnet: "Test SDF Network ; September 2015"
# Mainnet: "Public Global Stellar Network ; September 2015"
# [OPTIONAL] Default: testnet passphrase
NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Deployed StellarLend lending contract address.
# Obtain after deploying: soroban contract deploy --wasm ...
# Or copy from the project README testnet deployment.
# [REQUIRED]
CONTRACT_ID=

# Public key used as the fee-estimation (read-only simulation) account.
# [OPTIONAL] Default: project-provided testnet account
READ_ONLY_SIMULATION_ACCOUNT=GDZZJ3UPZZCKY5DBH6ZGMPMRORRBG4ECIORASBUAXPPNCL4SYRHNLYU2

# Secret key of the relayer account that sponsors fee-bump transactions.
# [SECRET] [OPTIONAL] Leave blank to disable relayer mode
RELAYER_SECRET=

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------

# Secret used to sign and verify JWT tokens. Must be at least 32 characters.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# [REQUIRED] [SECRET]
JWT_SECRET=

# How long issued JWTs remain valid (vercel/ms duration string).
# Examples: 1h, 24h, 7d
# [OPTIONAL] Default: 24h
JWT_EXPIRES_IN=24h

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------

# Comma-separated list of allowed frontend origins.
# In development this defaults to '*' (all origins) when not set.
# In production this defaults to restrictive (no origins) — set it explicitly.
# Example: https://app.stellarlend.io,https://staging.stellarlend.io
# [OPTIONAL in development, REQUIRED in production]
ALLOWED_ORIGINS=

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------

# Length of the sliding rate-limit window in milliseconds.
# [OPTIONAL] Default: 900000 (15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# Maximum requests per IP per window.
# [OPTIONAL] Default: 100
RATE_LIMIT_MAX_REQUESTS=100

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# Minimum log level emitted.
# Accepted values: error | warn | info | http | verbose | debug | silly
# [OPTIONAL] Default: info
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Request Timeouts & Retries
# -----------------------------------------------------------------------------

# Maximum time (ms) to wait for a Soroban RPC response before aborting.
# [OPTIONAL] Default: 30000 (30 s)
REQUEST_TIMEOUT=30000

# Number of automatic retries for transient network errors.
# [OPTIONAL] Default: 3
MAX_RETRIES=3

# Initial retry back-off delay (ms). Doubles each attempt up to RETRY_MAX_DELAY_MS.
# [OPTIONAL] Default: 1000
RETRY_INITIAL_DELAY_MS=1000

# Maximum retry back-off delay (ms).
# [OPTIONAL] Default: 10000
RETRY_MAX_DELAY_MS=10000

# -----------------------------------------------------------------------------
# Request Body Size
# -----------------------------------------------------------------------------

# Maximum allowed request body size. Requests exceeding this return HTTP 413.
# Supports unit suffixes: b | kb | mb | gb
# [OPTIONAL] Default: 100kb
BODY_SIZE_LIMIT=100kb

# -----------------------------------------------------------------------------
# Pagination
# -----------------------------------------------------------------------------

# Default page size for list endpoints.
# [OPTIONAL] Default: 10
PAGINATION_DEFAULT_LIMIT=10

# Hard upper bound on page size a client may request.
# [OPTIONAL] Default: 100
PAGINATION_MAX_LIMIT=100

# -----------------------------------------------------------------------------
# Redis Cache
# -----------------------------------------------------------------------------

# Set to "true" to enable Redis-backed caching and idempotency storage.
# [OPTIONAL] Default: false (in-memory store used)
REDIS_ENABLED=false

# Redis connection URL. Required when REDIS_ENABLED=true.
# [OPTIONAL] Default: redis://127.0.0.1:6379
REDIS_URL=redis://127.0.0.1:6379

# Time-to-live for idempotency keys (ms).
# [OPTIONAL] Default: 86400000 (24 h)
IDEMPOTENCY_TTL_MS=86400000

# Maximum number of in-flight idempotency entries (in-memory store only).
# [OPTIONAL] Default: 1000
IDEMPOTENCY_MAX_ENTRIES=1000

# TTL for protocol-stats cache entries (ms).
# [OPTIONAL] Default: 30000 (30 s)
PROTOCOL_STATS_TTL_MS=30000

# TTL for position cache entries (ms).
# [OPTIONAL] Default: 15000 (15 s)
POSITION_CACHE_TTL_MS=15000

# TTL for pool cache entries (ms).
# [OPTIONAL] Default: 30000 (30 s)
POOL_CACHE_TTL_MS=30000

# -----------------------------------------------------------------------------
# WebSocket / Price Feed
# -----------------------------------------------------------------------------

# Base URL of the oracle service that provides live price updates.
# [OPTIONAL] Leave blank to disable price-feed WebSocket
ORACLE_API_URL=

# How often the server pushes a price update to connected WebSocket clients (ms).
# [OPTIONAL] Default: 30000 (30 s)
WS_PRICE_UPDATE_INTERVAL_MS=30000

# How often a WebSocket heartbeat ping is sent (ms).
# [OPTIONAL] Default: 30000 (30 s)
WS_HEARTBEAT_INTERVAL_MS=30000

# -----------------------------------------------------------------------------
# Emergency Pause
# -----------------------------------------------------------------------------

# Number of consecutive Soroban RPC failures before the circuit-breaker
# automatically pauses the lending protocol.
# [OPTIONAL] Default: 5
AUTO_PAUSE_FAILURE_THRESHOLD=5

# -----------------------------------------------------------------------------
# Analytics
# -----------------------------------------------------------------------------

# Number of days of protocol snapshot history to retain.
# [OPTIONAL] Default: 90
ANALYTICS_HISTORY_RETENTION_DAYS=90

# How often a protocol snapshot is captured (ms).
# [OPTIONAL] Default: 60000 (1 min)
ANALYTICS_SNAPSHOT_INTERVAL_MS=60000

# -----------------------------------------------------------------------------
# Subscriptions (Recurring Operations)
# -----------------------------------------------------------------------------

# Maximum retry attempts for a failed recurring operation.
# [OPTIONAL] Default: 3
SUBSCRIPTION_MAX_RETRIES=3

# Back-off delay between subscription retries (ms).
# [OPTIONAL] Default: 5000 (5 s)
SUBSCRIPTION_RETRY_BACKOFF_MS=5000

# How often the subscription executor polls for due operations (ms).
# [OPTIONAL] Default: 300000 (5 min)
SUBSCRIPTION_EXECUTION_INTERVAL_MS=300000
